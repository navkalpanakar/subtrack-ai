# ──────────────────────────────────────────────────────────────
# SubTrack AI — Production Environment Variables
# Domain: subtrack.scanmymenu.in
# ──────────────────────────────────────────────────────────────

# ─── Database ──────────────────────────────────────────────────
# SQLite for now. For production scale, switch to PostgreSQL:
#   DATABASE_URL="postgresql://user:pass@localhost:5432/subtrack"
DATABASE_URL="file:/home/z/my-project/db/custom.db"

# ─── NextAuth ──────────────────────────────────────────────────
# Generate a new secret: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_32_CHAR_STRING"
# Your production subdomain
NEXTAUTH_URL="https://subtrack.scanmymenu.in"

# ─── Google OAuth ──────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Redirect URI: https://subtrack.scanmymenu.in/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Microsoft OAuth (Azure AD) ────────────────────────────────
# Get from: https://portal.azure.com → Microsoft Entra ID → App registrations
# Redirect URI: https://subtrack.scanmymenu.in/api/auth/callback/azure-ad
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID="common"

# ─── Apple Sign In (requires $99/yr Apple Developer account) ───
# Redirect URI: https://subtrack.scanmymenu.in/api/auth/callback/apple
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# ─── Email Sending (Resend — free 3,000/month) ────────────────
# Sign up at resend.com (free, no credit card needed)
# For production: add scanmymenu.in domain in Resend + verify DNS
RESEND_API_KEY=""
EMAIL_FROM="SubTrack AI <noreply@scanmymenu.in>"

# ─── Stripe Payments (Premium subscriptions) ───────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Create a recurring product: https://dashboard.stripe.com/products
# Set the Price ID below (price_xxx)
# Webhook URL: https://subtrack.scanmymenu.in/api/stripe/webhook
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PREMIUM_PRICE_ID=""
