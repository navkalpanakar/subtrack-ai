// SubTrack AI — AI-powered subscription tracker with gamification
// SQLite datasource (primitives only)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  phone         String?   @unique
  image         String?
  emailVerified DateTime?
  referralCode  String?   @unique
  referredBy    String?   // referral code of the inviter
  country       String?   // user's country (from geolocation)
  countryCode   String?   // ISO 2-letter code (e.g. "IN", "US")
  city          String?   // user's city
  currency      String?   // user's preferred currency (e.g. "INR", "USD")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  subscriptions Subscription[]
  progress      UserProgress?
  challenges    UserChallenge[]
  rewards       RedeemedReward[]
  badges        UserBadge[]
  linkedAccounts LinkedAccount[]
  referrals     Referral[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id              String   @id @default(cuid())
  userId          String
  name            String
  provider        String
  category        String   @default("Other")
  amount          Float
  currency        String   @default("USD")
  billingCycle    String   @default("monthly")
  nextBillingDate DateTime
  startDate       DateTime?
  status          String   @default("active")
  logo            String?
  color           String?
  notes           String?
  usageTags       String   @default("")
  cancelUrl       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([nextBillingDate])
}

// ─── Gamification ──────────────────────────────────────────────

model UserProgress {
  userId         String   @id
  points         Int      @default(0)
  level          Int      @default(1)
  streak         Int      @default(0)
  lastCheckIn    DateTime?
  savingsGoal    Int      @default(100) // monthly savings goal in USD
  totalSaved     Int      @default(0)   // cumulative $ saved via cancellations
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Challenge {
  id          String   @id @default(cuid())
  title       String
  detail      String
  points      Int
  goal        Int      // target count to complete
  icon        String   @default("target")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  userProgress UserChallenge[]
}

model UserChallenge {
  id          String   @id @default(cuid())
  userId      String
  challengeId String
  progress    Int      @default(0)
  completed   Boolean  @default(false)
  completedAt DateTime?
  claimedAt   DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
}

// Reward tiers unlockable with points (scratch-card coupon reveal)
model Reward {
  id          String   @id @default(cuid())
  title       String
  detail      String
  cost        Int      // points required
  tier        String   @default("bronze") // bronze | silver | gold
  icon        String   @default("gift")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  redeemed    RedeemedReward[]
}

model RedeemedReward {
  id        String   @id @default(cuid())
  userId    String
  rewardId  String
  offerTitle String?
  offerUrl  String?
  offerDetail String?
  revealed  Boolean  @default(false)
  redeemedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward    Reward   @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Badge {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "first_subscription"
  title     String
  detail    String
  icon      String
  userBadges UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

// Tracks which email providers a user has linked (google/microsoft/apple/email)
// so the Add-Subscription inbox sync knows whether to sync directly or prompt.
model LinkedAccount {
  id        String   @id @default(cuid())
  userId    String
  provider  String   // "google" | "microsoft" | "apple" | "email" | "phone"
  identifier String  // email or phone for the linked account
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

// Daily spin-the-wheel results (one free spin per day)
model SpinResult {
  id        String   @id @default(cuid())
  userId    String
  points    Int      // points won
  date      String   // YYYY-MM-DD (for daily-limit check)
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

// Referral system — track shares + installs
model Referral {
  id          String   @id @default(cuid())
  referrerId  String   // user who shared
  referredId  String?  // user who installed (null until they sign up)
  code        String   // the referral code shared
  status      String   @default("shared") // shared | installed | rewarded
  pointsAwarded Int    @default(0)
  createdAt   DateTime @default(now())
  installedAt DateTime?
  user        User     @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
}
